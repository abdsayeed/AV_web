# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-50-char-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.aris-ventures.com
DJANGO_SETTINGS_MODULE=config.settings.production

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=aries_ventures
DB_USER=aries_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://aris-ventures.com

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token TTL: 15 minutes. Refresh token TTL: 7 days.
# Tokens stored in HttpOnly cookies — not localStorage.

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Register at https://console.cloud.google.com/
# Authorised redirect URIs:
#   Local:  http://localhost:8000/auth/complete/google-oauth2/
#   Prod:   https://api.aris-ventures.com/auth/complete/google-oauth2/
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-client-id
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-client-secret

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get key at https://resend.com
# For local dev, use sandbox sender: onboarding@resend.dev
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TEAM_EMAIL=team@aris-ventures.com

# ─── Upstash Redis (Rate Limiting) ────────────────────────────────────────────
# Get at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Trigger.dev (Background Jobs) ───────────────────────────────────────────
# Get at https://trigger.dev
TRIGGER_API_KEY=tr_dev_your_trigger_key
TRIGGER_API_URL=https://api.trigger.dev

# ─── Uploadthing (File Uploads) ───────────────────────────────────────────────
UPLOADTHING_SECRET=sk_live_your_uploadthing_secret
UPLOADTHING_APP_ID=your-uploadthing-app-id

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─── Frontend (Angular) ───────────────────────────────────────────────────────
# Set in apps/web/src/environments/environment.prod.ts
NG_API_URL=https://api.aris-ventures.com/api
NG_WS_URL=wss://api.aris-ventures.com/ws
NG_FRONTEND_URL=https://aris-ventures.com
